


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - EMS PRO</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        .navbar-custom {
            background-color: #2c3e50;
            border-bottom: 3px solid #3498db;
        }

        .nav-link {
            color: #ecf0f1 !important;
            font-weight: 500;
        }

            .nav-link:hover {
                color: #3498db !important;
            }

        .navbar-brand {
            font-weight: bold;
            color: #fff !important;
        }

        .welcome-text {
            color: #bdc3c7;
            margin-right: 15px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-users-gear"></i> EMS PRO
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">@Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Employee List", "Index", "Employees", null, new { @class = "nav-link" })</li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">@Html.ActionLink("View Role", "Index", "Administrator", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Create Role", "RoleCreate", "Administrator", null, new { @class = "nav-link" })</li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="welcome-text">Welcome, @User.Identity.Name!</span>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Logout", "Account")" class="btn btn-danger btn-sm text-white">
                                <i class="fa-solid fa-right-from-bracket"></i> Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-sm me-2 text-white">Login</a>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Registration", "Register", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content mt-4">
        @RenderBody()
        <hr />
        <footer class="text-muted text-center pb-3">
            <p>&copy; @DateTime.Now.Year - Employee Management System | Developed by Sumaiya</p>
        </footer>
    </div>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>